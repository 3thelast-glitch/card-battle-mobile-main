# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — NEVER commit these
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs
*.log

# OS
Thumbs.db

# Build files
*.tgz
*.tar.gz
.cache/

# Lock files — use pnpm only
package-lock.json
yarn.lock

# VSCode local history (should never be committed)
.history/

# Disabled/internal git folders
.git_disabled/

# Editor snapshots
.snapshots/

# Generated type declaration (auto-produced, do not commit manually)
theme.config.d.ts

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Card Clash — Environment Variables (EXAMPLE)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 1. انسخ هذا الملف وسمّه .env
#    cp .env.example .env
#
# 2. غيّر القيم حسب بيئتك
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── Multiplayer Server ────────────────────────────────────
# عنوان WebSocket للسيرفر
# • تطوير محلي  → استخدم IP جهازك (مو localhost)
# • نشر حقيقي  → استخدم domain السيرفر

EXPO_PUBLIC_MP_SERVER_URL=ws://YOUR_LOCAL_IP:3001/multiplayer


# ── أمثلة ─────────────────────────────────────────────────
# تطوير محلي (استبدل YOUR_LOCAL_IP بـ IP جهازك الفعلي):
# EXPO_PUBLIC_MP_SERVER_URL=ws://192.168.x.x:3001/multiplayer
#
# نشر على Railway / Render:
# EXPO_PUBLIC_MP_SERVER_URL=wss://card-clash-server.railway.app/multiplayer
